# Copy this file to /etc/pixel.env on the server and replace the values.
# Then `chmod 600 /etc/pixel.env` and `systemctl restart pixel`.

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=replace-with-a-long-random-hex-string

# Teacher login password (for /teacher)
TEACHER_PASSWORD=replace-with-your-teacher-password
